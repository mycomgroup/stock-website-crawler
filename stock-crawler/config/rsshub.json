{
  "name": "rsshub-routes-docs",
  "seedUrls": [
    "https://docs.rsshub.app/routes/"
  ],
  "urlRules": {
    "include": [
      "^https://docs\\.rsshub\\.app/routes/.*"
    ],
    "exclude": []
  },
  "login": {
    "required": false,
    "username": "",
    "password": "",
    "loginUrl": ""
  },
  "crawler": {
    "headless": true,
    "timeout": 60000,
    "waitBetweenRequests": 1000,
    "maxRetries": 3,
    "batchSize": 10,
    "userDataDir": "./chrome_user_data_rsshub"
  },
  "output": {
    "directory": "./output/rsshub",
    "format": "markdown"
  }
}