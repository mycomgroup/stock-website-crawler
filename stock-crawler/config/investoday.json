{
  "name": "investoday-data-api-docs",
  "seedUrls": [
    "https://data-api.investoday.net/"
  ],
  "urlRules": {
    "include": [
      "^https://data-api\\.investoday\\.net(?:/.*)?$"
    ],
    "exclude": [
      "^https://data-api\\.investoday\\.net/assets/.*$",
      "^https://data-api\\.investoday\\.net/.*\\.(?:js|css|png|jpg|jpeg|gif|svg|ico|woff2?|ttf)(?:\\?.*)?$",
      "^https://data-api\\.investoday\\.net/(?:favicon\\.ico|robots\\.txt|sitemap\\.xml)$"
    ]
  },
  "login": {
    "required": false,
    "username": "",
    "password": "",
    "loginUrl": ""
  },
  "crawler": {
    "headless": true,
    "timeout": 90000,
    "waitBetweenRequests": 3000,
    "maxRetries": 3,
    "batchSize": 20,
    "maxPages": 200
  },
  "output": {
    "directory": "./output",
    "format": "markdown"
  }
}
