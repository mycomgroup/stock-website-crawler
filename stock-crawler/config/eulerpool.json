{
  "name": "eulerpool-api-docs",
  "seedUrls": [
    "https://eulerpool.com/developers/"
  ],
  "urlRules": {
    "include": [
      "^https://eulerpool\\.com/developers/api/.*"
    ],
    "exclude": []
  },
  "login": {
    "required": false,
    "username": "",
    "password": "",
    "loginUrl": ""
