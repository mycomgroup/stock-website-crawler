{
  "name": "infoway-api-docs",
  "seedUrls": [
    "https://docs.infoway.io/"
  ],
  "urlRules": {
    "include": [
      "^https://docs\\.infoway\\.io/.*"
    ],
    "exclude": [
      "\\~gitbook/",
      "\\~image",
      "\\.png$",
      "\\.jpg$",
      "\\.svg$",
      "\\.css$",
      "\\.js$",
      "/rss\\.xml",
      "/readme\\.md"
    ]
  },
  "login": {
    "required": false,
    "username": "",
    "password": "",
    "loginUrl": ""
  },
  "crawler": {
    "headless": true,
    "timeout": 60000,
    "waitBetweenRequests": 1500,
    "maxRetries": 3,
    "batchSize": 30,
    "userDataDir": "./chrome_user_data_infoway"
  },
  "output": {
    "directory": "./output",
    "format": "markdown"
  }
}