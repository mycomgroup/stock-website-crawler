{
  "name": "template-content-analyzer",
  "version": "1.0.0",
  "description": "Analyze markdown page content to identify template patterns and unique data",
  "author": "",
  "type": "analyzer",
  "entry": "main.js",
  "inputs": {
    "urlPatternsFile": {
      "type": "string",
      "description": "Path to url-patterns.json file",
      "required": true,
      "example": "stock-crawler/output/lixinger-crawler/url-patterns.json"
    },
    "pagesDir": {
      "type": "string",
      "description": "Path to pages directory containing markdown files",
      "required": true,
      "example": "stock-crawler/output/lixinger-crawler/pages"
    },
    "outputFile": {
      "type": "string",
      "description": "Path to output JSONL file",
      "required": true,
      "example": "stock-crawler/output/lixinger-crawler/template-rules.jsonl"
    },
    "sampleUrls": {
      "type": "array",
      "description": "Optional sample URLs for real-time validation",
      "required": false,
      "example": ["https://www.lixinger.com/open/api/doc?api-key=cn/company"]
    },
    "frequencyThresholds": {
      "type": "object",
      "description": "Frequency thresholds for content classification",
      "required": false,
      "default": {
        "template": 0.8,
        "unique": 0.2
      }
    }
  },
  "outputs": {
    "success": {
      "type": "boolean",
      "description": "Whether the analysis was successful"
    },
    "configFile": {
      "type": "string",
      "description": "Path to the generated config file"
    },
    "configsGenerated": {
      "type": "number",
      "description": "Number of template configs generated"
    },
    "totalExtractors": {
      "type": "number",
      "description": "Total number of extractors generated"
    },
    "totalFilters": {
      "type": "number",
      "description": "Total number of filters generated"
    },
    "configs": {
      "type": "array",
      "description": "Summary of generated configs"
    }
  },
  "dependencies": [],
  "keywords": [
    "template-analysis",
    "content-analysis",
    "frequency-analysis",
    "markdown-parser",
    "web-crawler"
  ]
}
