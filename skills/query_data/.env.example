# Query Data Plugin - 环境变量模板
# 复制此文件为 .env 并填入你的API密钥

# ===========================================
# 美股数据源（国际）
# ===========================================

# Finnhub - 美股实时数据
# 获取地址: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# Financial Modeling Prep - 美股财务数据
# 获取地址: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_fmp_api_key_here

# Alpha Vantage - 美股历史数据
# 获取地址: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# Tiingo - 美股历史数据
# 获取地址: https://api.tiingo.com/
TIINGO_API_KEY=your_tiingo_api_key_here

# EODHD - 全球股票数据
# 获取地址: https://eodhd.com/
EODHD_API_KEY=your_eodhd_api_key_here

# ===========================================
# 搜索与信息API
# ===========================================

# Brave Search - 隐私搜索引擎
# 获取地址: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# Tavily - AI搜索
# 获取地址: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# SerpAPI - Google搜索结果
# 获取地址: https://serpapi.com/
SERP_API_KEY=your_serpapi_key_here

# ===========================================
# 专业金融数据
# ===========================================

# Eulerpool - 投资数据
# 获取地址: https://eulerpool.com/
EULERPOOL_API_KEY=your_eulerpool_api_key_here

# Massive - 金融数据
# 获取地址: https://massive.com/
MASSIVE_API_KEY=your_massive_api_key_here

# AllTick - 实时行情（WebSocket）
# 获取地址: https://alltick.co/
ALLTICK_API_KEY=your_alltick_api_key_here

# Financial Datasets - AI金融数据
# 获取地址: https://financialdatasets.ai/
FINANCIALDATASETS_API_KEY=your_financialdatasets_api_key_here

# ===========================================
# 中国A股数据源（理杏仁）
# ===========================================

# 理杏仁 - 最全面的中文金融数据
# 获取地址: https://www.lixinger.com
# 1. 注册账号
# 2. 进入个人中心
# 3. 复制API Token
LIXINGER_TOKEN=your_lixinger_token_here

# ===========================================
# 使用说明
# ===========================================
# 
# 1. 复制此文件: cp .env.example .env
# 2. 编辑 .env 文件，填入你的API密钥
# 3. 加载环境变量: source .env
# 4. 运行测试: python3 test_datasource.py
#
# 注意: .env 文件包含敏感信息，请勿提交到Git仓库！
#      已在 .gitignore 中排除
