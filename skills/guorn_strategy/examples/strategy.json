{
  "name": "低PE高ROE策略",
  "description": "选择PE低于30且ROE排名前10的股票",
  "stockPool": {
    "type": "system",
    "poolId": "hs300",
    "stockLimit": 10,
    "rebalanceCycle": 20
  },
  "filters": [
    {
      "indicator": "pe_ttm",
