      "indicator": "roe",
      "order": "desc",
      "weight": 0.6
    },
    {
      "indicator": "revenue_growth",
      "order": "desc",
      "weight": 0.4
    }
  ],
  "tradingModel": {
    "type": 1,
    "rebalanceCycle": 20,
    "rebalanceTime": "close",
    "maxPosition": 10,
    "positionWeight": "equal"
  }
}
