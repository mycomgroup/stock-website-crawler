{
  "name": "url-pattern-analyzer",
  "version": "1.0.0",
  "description": "Analyze URL patterns from links.txt and generate pattern reports",
  "author": "",
  "type": "analyzer",
  "entry": "main.js",
  "inputs": {
    "linksFile": {
      "type": "string",
      "description": "Path to links.txt file",
      "required": true,
      "example": "stock-crawler/output/lixinger-crawler/links.txt"
    },
    "outputFile": {
      "type": "string",
      "description": "Path to output JSON file",
      "required": true,
      "example": "stock-crawler/output/lixinger-crawler/url-patterns.json"
    },
    "minGroupSize": {
      "type": "number",
      "description": "Minimum number of URLs in a group",
      "required": false,
      "default": 5
    }
  },
  "outputs": {
    "success": {
      "type": "boolean",
      "description": "Whether the analysis was successful"
    },
    "patternsFile": {
      "type": "string",
      "description": "Path to the generated patterns file"
    },
    "patternCount": {
      "type": "number",
      "description": "Number of patterns identified"
    },
    "totalUrls": {
      "type": "number",
      "description": "Total number of URLs analyzed"
    },
    "patterns": {
      "type": "array",
      "description": "Array of identified URL patterns"
    }
  },
  "dependencies": [],
  "keywords": [
    "url-analysis",
    "pattern-recognition",
    "clustering",
    "web-crawler"
  ]
}
